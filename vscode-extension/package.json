{
  "name": "pigeon-chat",
  "displayName": "Pigeon Chat",
  "description": "Keystroke-aware chat panel. Classifies cognitive state from typing patterns and injects live operator context into every LLM response.",
  "version": "0.1.0",
  "publisher": "savagecoo",
  "repository": "https://github.com/SavageCooPigeonX/keystroke-telemetry",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["AI", "Other"],
  "activationEvents": ["onStartupFinished", "onCommand:pigeon.openChat", "onCommand:pigeon.showOperatorState", "onCommand:pigeon.showEntropyChart", "onCommand:pigeon.showFreshnessSurface"],
  "main": "./out/extension",
  "contributes": {
    "chatParticipants": [
      {
        "id": "pigeon-telemetry.capture",
        "fullName": "Pigeon Telemetry",
        "name": "pigeon",
        "description": "Keystroke-aware cognitive telemetry — captures prompts for operator state analysis",
        "isSticky": false
      }
    ],
    "commands": [
      {
        "command": "pigeon.openChat",
        "title": "Pigeon: Open Keystroke-Aware Chat"
      },
      {
        "command": "pigeon.showOperatorState",
        "title": "Pigeon: Show Live Operator State"
      },
      {
        "command": "pigeon.showEntropyChart",
        "title": "Pigeon: Show Per-File Entropy Chart"
      },
      {
        "command": "pigeon.showFreshnessSurface",
        "title": "Pigeon: Show Freshness Surface"
      },
      {
        "command": "pigeon.cascadeScaleUp",
        "title": "Pigeon: Cascade Scale Up"
      },
      {
        "command": "pigeon.cascadeScaleDown",
        "title": "Pigeon: Cascade Scale Down"
      },
      {
        "command": "pigeon.cascadeScaleAuto",
        "title": "Pigeon: Cascade Scale Auto"
      },
      {
        "command": "pigeon.showWorkLoopReasoning",
        "title": "Pigeon: Show Work Loop Reasoning"
      },
      {
        "command": "pigeon.standup",
        "title": "Pigeon: Cascade Standup — What's Going On"
      }
    ],
    "configuration": {
      "title": "Pigeon Chat",
      "properties": {
        "pigeon.openFreshnessSurfaceOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the Pigeon freshness surface when the extension activates."
        }
      }
    },
    "keybindings": [
      {
        "command": "pigeon.openChat",
        "key": "ctrl+shift+p",
        "when": "false"
      },
      {
        "command": "pigeon.cascadeScaleUp",
        "key": "ctrl+up",
        "when": "editorTextFocus"
      },
      {
        "command": "pigeon.cascadeScaleDown",
        "key": "ctrl+down",
        "when": "editorTextFocus"
      },
      {
        "command": "pigeon.cascadeScaleAuto",
        "key": "ctrl+shift+0",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "node_modules\\.bin\\tsc.cmd -p ./",
    "watch": "node_modules\\.bin\\tsc.cmd -watch -p ./",
    "package": "node_modules\\.bin\\vsce.cmd package"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0"
  }
}
