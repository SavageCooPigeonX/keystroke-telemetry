# Optional: only required for Pigeon Compiler flows that call DeepSeek.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_CODING_MODEL=deepseek-v4-pro
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
# Set to 1 only when you want prompt-triggered DeepSeek jobs to patch files.
DEEPSEEK_AUTONOMOUS_PROMPT_WRITES=0
